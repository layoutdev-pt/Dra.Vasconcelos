{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/pt/:path*",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/pt",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/pt/",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}